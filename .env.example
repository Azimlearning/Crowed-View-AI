# Venue Intelligence AI - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Required: Google Gemini API Key for AI suggestions
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (via OpenRouter) for suggestions
OPENROUTER_API_KEY=your_openrouter_api_key_here

# RTSP camera URL (Imou Ranger 2)
# Format: rtsp://admin:<SAFETY_CODE>@<CAMERA_IP>:554/cam/realmonitor?channel=1&subtype=1
# Leave blank to use local webcam
RTSP_URL=

# Optional: Camera index (0, 1, 2, etc.)
# Use this if you have multiple cameras and need to specify which one to use
# Default: tries indices 0, 1, 2 in order
# CAMERA_INDEX=0

# Optional: Video file path for fallback mode
# If camera is unavailable, system can use a video file instead
# VIDEO_FILE_PATH=path/to/video.mp4
